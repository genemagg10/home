# ─── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Used by ingestion/embedding routes. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Claude (chat + upload tagging) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides (sensible defaults are baked in)
HOMEBASE_CHAT_MODEL=claude-opus-4-8
HOMEBASE_EXTRACT_MODEL=claude-haiku-4-5

# ─── Embeddings (RAG vectors) ────────────────────────────────────────────────
# Anthropic has no embeddings endpoint, so RAG uses OpenAI embeddings by default.
# text-embedding-3-small is 1536-dim and matches the pgvector column in the schema.
OPENAI_API_KEY=sk-...
HOMEBASE_EMBED_MODEL=text-embedding-3-small

# ─── Site URL ────────────────────────────────────────────────────────────────
# Your public URL. On Vercel this is auto-detected (VERCEL_URL); set this only
# if you use a custom domain. Locally you can leave it unset (defaults to :3000).
NEXT_PUBLIC_SITE_URL=

# ─── Weather (Open-Meteo, no key needed) ─────────────────────────────────────
# Your house location, used for the live weather strip + freeze/heat surfacing.
HOMEBASE_LAT=39.7684
HOMEBASE_LON=-86.1581

# ─── Google Calendar (one-way push, optional) ────────────────────────────────
# Create an OAuth 2.0 Client (Web) in Google Cloud Console.
# The redirect URI is derived from your site URL automatically
# (<site>/api/calendar/callback) — only set GOOGLE_REDIRECT_URI to override.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ─── Vercel Cron (optional) ──────────────────────────────────────────────────
# If set, the daily calendar-sync cron must present this as a bearer token.
# Vercel injects it automatically when you add it as a project env var.
CRON_SECRET=
